# Copie para ".env" e ajuste. No Render, defina essas variáveis no painel do serviço.
# NODE_ENV=production é definido automaticamente pelo Render.

# Segredo usado para assinar os cookies de sessão (gere um valor longo e aleatório).
# SESSION_SECRET=gere_um_valor_longo_e_aleatorio_aqui

# Opcional: ativa o login com Google (deixe vazio para desativar).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Sincronização do banco (SQLite) do Render para ESTE repositório GitHub.
# Token compartilhado entre o servidor e o script sync-db.js (obrigatório).
DB_SYNC_TOKEN=defina_um_token_longo_e_aleatorio_aqui

# URL do site hospedado no Render (origem do .db).
# SYNC_SERVER=https://the-gods-studio.onrender.com

# === E-MAIL (verificação, troca de e-mail/senha, 2FA, desconexão) ===
# OBRIGATÓRIO EM PRODUÇÃO. Sem SMTP, os e-mails NÃO são entregues e a interface
# passa a exibir um erro real (em vez de confirmar o envio com sucesso).
# No modo dev (NODE_ENV=development) sem SMTP, o conteúdo é salvo em
# data/emails/*.html apenas para inspeção.
# Nunca coloque uma senha real neste arquivo. Configure SMTP_PASS apenas no Render.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=luismetzker9@gmail.com
# SMTP_PASS=
# MAIL_FROM=The Gods Studio <luismetzker9@gmail.com>

# === SINCRONIZAÇÃO DO BANCO (.db) PARA O REPOSITÓRIO GITHUB ===
# A cada 5 minutos: baixa o .db mais recente do servidor (Render), atualiza o
# arquivo no repositório, faz commit SÓ se houve alteração e faz git push.
# NÃO envia mais nada para o computador local.
# SYNC_SERVER=https://the-gods-studio.onrender.com
# DB_SYNC_TOKEN=defina_um_token_longo_e_aleatorio_aqui
# DB_REPO_PATH=db/accounts.db
# GIT_REMOTE=origin
# GIT_BRANCH=main
# GIT_USER_NAME=DB Sync Bot
# GIT_USER_EMAIL=luismetzker9@gmail.com
